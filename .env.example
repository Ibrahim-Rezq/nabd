# nabd — environment variables
# Copy to .env.local and fill with real values. .env.local is gitignored.
# Real values live in the Vercel and Supabase dashboards, not in the repo.

# --- Site ---
# Canonical origin used for metadata, sitemap, robots, and OG image URLs.
# Falls back to https://nabd.app when unset.
NEXT_PUBLIC_SITE_URL=

# --- Supabase (sync + auth) ---
# Project URL and anon (publishable) key — safe to expose to the browser.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# NOTE: there is intentionally no service-role key here. The app has no server tier (all
# Supabase access is client-side with the anon key + RLS). Do NOT reintroduce a service-role
# key unless a real server route needs it, and never with a NEXT_PUBLIC_ prefix (audit F-INFO-a).

# --- Sentry (error tracking) ---
# DSN is client-safe; auth token is used only at build time for source maps (CI/local).
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_AUTH_TOKEN=
SENTRY_ORG=
SENTRY_PROJECT=

# --- Vercel Analytics ---
# No env var required for @vercel/analytics on Vercel; it is enabled in the dashboard.
# (Listed here so the full observability setup is visible in one place — see NBD-11.)
