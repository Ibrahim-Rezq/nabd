{
  "name": "nabd",
  "version": "0.48.1",
  "private": true,
  "packageManager": "pnpm@10.29.3",
  "pnpm": {
    "overrides": {
      "sharp": ">=0.35.0",
      "postcss": ">=8.5.10",
      "fast-uri": ">=3.1.4"
    }
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build --webpack",
    "build:native": "rm -f public/sw.js public/sw.js.map && NEXT_PUBLIC_BUILD_TARGET=native next build --webpack",
    "cap:sync": "pnpm build:native && capacitor sync android",
    "start": "next start",
    "lint": "eslint",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "check:colocated": "node scripts/check-colocated-tests.mjs",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "prepare": "husky"
  },
  "dependencies": {
    "@capacitor/app": "^7",
    "@capacitor/browser": "^7",
    "@capacitor/core": "^7",
    "@capacitor/geolocation": "^7",
    "@capacitor/local-notifications": "^7",
    "@capawesome-team/capacitor-android-battery-optimization": "^7",
    "@sentry/nextjs": "^10.65.0",
    "@serwist/next": "^9.5.11",
    "@supabase/ssr": "^0.12.1",
    "@supabase/supabase-js": "^2.110.3",
    "@vercel/analytics": "^2.0.1",
    "adhan": "^4.4.4",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dexie": "^4.4.4",
    "dexie-react-hooks": "^4.4.0",
    "lucide-react": "^1.24.0",
    "next": "16.2.10",
    "radix-ui": "^1.6.2",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "serwist": "^9.5.11",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@capacitor/android": "^7",
    "@capacitor/cli": "^7",
    "@commitlint/cli": "^21.2.1",
    "@commitlint/config-conventional": "^21.2.0",
    "@playwright/test": "^1.61.1",
    "@tailwindcss/postcss": "^4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^6.0.3",
    "eslint": "^9",
    "eslint-config-next": "16.2.10",
    "fake-indexeddb": "^6.2.5",
    "husky": "^9.1.7",
    "jsdom": "^29.1.1",
    "lint-staged": "^17.0.8",
    "prettier": "^3.9.5",
    "shadcn": "^4.13.0",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vitest": "^4.1.10"
  }
}
